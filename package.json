{
  "name": "codinfy-agent-monitor-workspace",
  "version": "0.1.2",
  "private": true,
  "description": "Codinfy Agent Monitor monorepo",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm build && pnpm test && pnpm format:check && node packages/cli/dist/index.js secrets && node packages/cli/dist/index.js attribution-check",
    "codinfy": "node packages/cli/dist/index.js",
    "mcp": "node packages/mcp-server/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
